  "project": {
    "submitLabel": "Send Project Enquiry",
    "fields": [
      {
        "id": "name",
        "label": "Full Name",
        "type": "text",
        "required": true,
        "half": true
      },
      {
        "id": "email",
        "label": "Your Email",
        "type": "email",
        "required": true,
        "half": true
      },
      {
        "id": "projectTitle",
        "label": "Project Title",
        "type": "text",
        "required": true
      },
      {
        "id": "description",
        "label": "Project Description",
        "type": "textarea",
        "required": true,
        "placeholder": "What do you need built? Include context and goals."
      },
      {
        "id": "currency",
        "label": "Currency",
        "type": "currency",
        "required": true,
        "half": true
      },
      {
        "id": "budget",
        "label": "Budget",
        "type": "text",
        "required": true,
        "half": true,
        "placeholder": "e.g. 500 – 1000"
      },
      {
        "id": "timeline",
        "label": "Timeline",
        "type": "text",
        "required": true,
        "placeholder": "e.g. 2 weeks"
      },
      {
        "id": "requirements",
        "label": "Technical Requirements",
        "type": "textarea",
        "required": false,
        "placeholder": "Optional — specific tech stack, APIs, or constraints."
      },
      {
        "id": "docLink",
        "label": "Requirements Document Link (optional)",
        "type": "url",
        "required": false,
        "placeholder": "Paste Google Drive, Dropbox, or OneDrive link",
        "hint": "⚠️ Before sharing, make sure the link permission is set to <strong>\"Anyone with the link can view\"</strong> — otherwise the document won't be accessible."
      }
    ]
  },
  "permanent": {
    "submitLabel": "Send Opportunity",
    "fields": [
      {
        "id": "name",
        "label": "Your Full Name",
        "type": "text",
        "required": true,
        "half": true
      },
      {
        "id": "email",
        "label": "Your Email",
        "type": "email",
        "required": true,
        "half": true
      },
      {
        "id": "company",
        "label": "Company Name",
        "type": "text",
        "required": true,
        "half": true
      },
      {
        "id": "position",
        "label": "Position Title",
        "type": "text",
        "required": true,
        "half": true
      },
      {
        "id": "workType",
        "label": "Work Type",
        "type": "select",
        "required": true,
        "half": true,
        "options": [
          "Remote",
          "On-site",
          "Hybrid"
        ]
      },
      {
        "id": "location",
        "label": "Location",
        "type": "text",
        "required": true,
        "half": true,
        "placeholder": "e.g. Lahore / Remote"
      },
      {
        "id": "currency",
        "label": "Currency",
        "type": "currency",
        "required": true,
        "half": true
      },
      {
        "id": "salary",
        "label": "Salary Range",
        "type": "text",
        "required": true,
        "half": true,
        "placeholder": "e.g. 3000 – 5000 / month"
      },
      {
        "id": "startDate",
        "label": "Start Date",
        "type": "text",
        "required": true,
        "placeholder": "e.g. ASAP or March 2026"
      },
      {
        "id": "description",
        "label": "Job Description",
        "type": "textarea",
        "required": true,
        "placeholder": "Describe the role, responsibilities, and team."
      },
      {
        "id": "reason",
        "label": "Why reach out?",
        "type": "textarea",
        "required": false,
        "placeholder": "Optional — what made you reach out specifically?"
      }
    ]
  }
}